#!/bin/sh
#
# PROVIDE: tubenews_web
# REQUIRE: NETWORKING
# KEYWORD: shutdown
#
# Add the following to /etc/rc.conf[.local] to enable this service:
#
# tubenews_web_enable="YES"

. /etc/rc.subr

name="tubenews_web"
rcvar=tubenews_web_enable
pidfile="/var/www/TubeNews/state/tubenews_web.pid"

: ${tubenews_web_enable:="NO"}
: ${tubenews_web_dir:="/var/www/TubeNews"}

command="/usr/sbin/daemon"
command_args="-P ${pidfile} ${tubenews_web_dir}/serve.sh"

load_rc_config $name
run_rc_command "$1"
